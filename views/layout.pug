doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Fotaza
    link(rel="stylesheet" href="/styles.css")
    block head
  body
    nav.nav
      a(href="/") Inicio
      if usuario
        a(href="/publicaciones/crear") Publicar
        a(href="/auth/logout") Cerrar sesión (#{usuario.username})
      else
        a(href="/auth/login") Iniciar sesión
        a(href="/auth/registro") Registrarse

    main.main-content
      block content

    footer.footer
      p 2026 Fotaza - Proyecto ULP - Web II - Godoy Dario