extends ../layout.pug

block content
  .detalle-container
    h1= publicacion.titulo
    p
      strong Autor: 
      a(href=`/usuarios/${publicacion.autor.id}`)= publicacion.autor.username

    if publicacion.descripcion
      p= publicacion.descripcion

    //- Sección de Imágenes
    .imagenes
      each imagen in publicacion.imagenes
        .imagen-item
          img(src=imagen.url alt=publicacion.titulo)
          p
            strong Licencia: 
            span= imagen.licencia
          
          if imagen.dataValues.promedio
            p
              strong Valoración: 
              span= imagen.dataValues.promedio + '/5 (' + imagen.dataValues.totalVotos + ' votos)'
          else
            p Sin valoraciones aún

          //- Sistema de votación (visible solo para usuarios autenticados que no sean el autor)
          if usuario && usuario.id !== publicacion.autor.id
            if imagen.dataValues.miValoracion
              p.ya-valorado
                | Ya valoraste con 
                each val in [1, 2, 3, 4, 5]
                  span(class=val <= imagen.dataValues.miValoracion ? 'estrella-llena' : 'estrella-vacia') ★
            else
              form.form-estrellas(action=`/publicaciones/imagen/${imagen.id}/valorar` method="post")
                .estrellas-input
                  each val in [5, 4, 3, 2, 1]
                    input(type="radio" id=`star${val}-${imagen.id}` name="valor" value=`${val}`)
                    label(for=`star${val}-${imagen.id}`) ★
                button(type="submit") Valorar

    //- Sección de Etiquetas (visible solo si hay etiquetas asociadas)
    if publicacion.etiquetas && publicacion.etiquetas.length > 0
      p
        strong Etiquetas: 
        each etiqueta in publicacion.etiquetas
          span.etiqueta= etiqueta.nombre + ' '

    hr

    //- Sección de Comentarios
    h2 Comentarios
    if publicacion.comentarios_abiertos
      if usuario
        form(action=`/publicaciones/${publicacion.id}/comentar` method="post")
          textarea(name="texto" placeholder="Escribí un comentario..." rows="3" required)
          button(type="submit") Comentar
      else
        p
          a(href="/auth/login") Iniciá sesión 
          |  para comentar

    if publicacion.comentarios && publicacion.comentarios.length > 0
      each comentario in publicacion.comentarios
        .comentario
          strong= comentario.autor.username
          p= comentario.texto
    else
      p No hay comentarios aún.