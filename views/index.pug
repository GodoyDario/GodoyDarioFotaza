extends layout.pug

block content
  h1 Explorar Publicaciones

  form(action="/" method="GET")
    input(
      type="text"
      name="search"
      placeholder="Buscar por título o descripción..."
      value=busqueda
    )
    button(type="submit") Buscar
    if busqueda
      a(href="/") Limpiar filtros

  if publicaciones && publicaciones.length > 0
    .galeria
      each pub in publicaciones
        .tarjeta-foto
          h3= pub.titulo
          if pub.imagenes && pub.imagenes.length > 0
            img(src=pub.imagenes[0].url alt=pub.titulo)
          if pub.descripcion
            p= pub.descripcion
          p
            strong Autor: 
            span= pub.autor.username
          a(href=`/publicaciones/${pub.id}`) Ver detalles
  else
    if busqueda
      p No se encontraron resultados para "#{busqueda}".
    else
      p No hay publicaciones disponibles.