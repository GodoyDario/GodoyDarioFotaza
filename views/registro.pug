extends layout.pug

block head
  link(rel="stylesheet" href="/stylesAuth.css")

block content
  .login-container
    h1 Fotaza
    p Una plataforma para compartir tus mejores fotos con amigos.

    if error
      p.error-message= error

    form(action="/auth/registro" method="post")
      p.section-title Creá tu cuenta
      .form-group
        label(for="username") Nombre de usuario
        input(type="text" id="username" name="username" placeholder="Tu usuario" required)
      .form-group
        label(for="email") Correo electrónico
        input(type="email" id="email" name="email" placeholder="tucorreo@ejemplo.com" required)
      .form-group
        label(for="password") Contraseña
        input(type="password" id="password" name="password" placeholder="Contraseña" required)
      .form-group
        label(for="confirmar_password") Confirmar contraseña
        input(type="password" id="confirmar_password" name="confirmar_password" placeholder="Repetí tu contraseña" required)
      button.btn-login(type="submit") Registrarse

    .login-footer
      p.small
        | ¿Ya tenés cuenta?
        a(href="/auth/login")  Iniciá sesión